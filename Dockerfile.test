# Dockerfile.test — Unit / Integration Test Runner
#
# Runs `npm run test:unit` inside an isolated Alpine container.
#
# Key design decisions:
#   1. node:20-alpine matches .nvmrc (20.19.0) and keeps the image lean.
#   2. git is installed so sibling repos can be cloned at build time.
#   3. Both sibling projects (paraty_geocore.js and bessa_patterns.ts) are
#      cloned into /workspace/ so that jest.config.unit.js moduleNameMapper
#      paths (../paraty_geocore.js, ../bessa_patterns.ts) resolve correctly —
#      no test-file changes required.
#   4. ENV NODE_ENV=test before npm ci ensures devDependencies are installed
#      (node:20-alpine ships with NODE_ENV=production which silently skips them).

FROM node:20-alpine

# git is needed to clone sibling repositories
RUN apk add --no-cache git

# ─── Sibling project dependencies ──────────────────────────────────────────
# jest.config.unit.js maps CDN/alias imports to local sibling dirs:
#   ../paraty_geocore.js/src/index
#   ../bessa_patterns.ts/src/index
# Cloning them here so the relative paths resolve inside the container.

WORKDIR /workspace

RUN git clone --depth 1 \
    --branch v0.12.11-alpha \
    https://github.com/mpbarbosa/paraty_geocore.js.git

RUN git clone --depth 1 \
    https://github.com/mpbarbosa/bessa_patterns.ts.git

# ─── Project setup ──────────────────────────────────────────────────────────

WORKDIR /workspace/guia_js

COPY package.json package-lock.json ./

# Override NODE_ENV before npm ci so devDependencies (Jest, ts-jest, etc.) are installed.
# The base image ships with NODE_ENV=production which would skip them silently.
ENV NODE_ENV=test
RUN npm ci --ignore-scripts

COPY . .

CMD ["npm", "run", "test:unit"]
