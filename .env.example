# Environment Configuration for Guia Turístico
# Copy .env.example to .env and adjust values for your environment.
# Variables prefixed with VITE_ are exposed to the browser via import.meta.env.
# DO NOT commit secrets or private values to version control.

# API Configuration
VITE_NOMINATIM_API_URL=https://nominatim.openstreetmap.org
VITE_NOMINATIM_USER_AGENT=GuiaTuristico/0.11.0
VITE_IBGE_API_URL=https://servicodados.ibge.gov.br

# AWS Location Based Service (primary geocoder)
# Leave VITE_AWS_LBS_BASE_URL empty to disable AWS and use only Nominatim.
VITE_AWS_LBS_BASE_URL=https://b2inkriw8k.execute-api.us-east-1.amazonaws.com
VITE_AWS_LBS_ENABLED=true

# Rate Limiting (requests per minute)
VITE_RATE_LIMIT_NOMINATIM=60
VITE_RATE_LIMIT_IBGE=120

# Feature Flags
VITE_ENABLE_SPEECH_SYNTHESIS=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=false

# Development Settings
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# Security
VITE_CSP_ENABLED=true
VITE_CORS_ENABLED=false
