# Environment Configuration for Guia Turístico
# Copy .env.example to .env and adjust values for your environment.
# Variables prefixed with VITE_ are exposed to the browser via import.meta.env.
# DO NOT commit secrets or private values to version control.

# API Configuration
VITE_NOMINATIM_API_URL=https://nominatim.openstreetmap.org
VITE_NOMINATIM_USER_AGENT=GuiaTuristico/0.11.0
VITE_IBGE_API_URL=https://servicodados.ibge.gov.br

# AWS Location Based Service
# Leave VITE_AWS_LBS_BASE_URL empty (default) so the Vite dev-server proxy
# forwards /api/* requests to AWS server-side — bypassing browser CORS.
# In production, set this to the full AWS URL if CORS is configured there.
VITE_AWS_LBS_BASE_URL=
VITE_AWS_LBS_ENABLED=true

# Geocoding provider order: 'aws' (default) or 'nominatim'
# 'aws'      → AWS is the primary geocoder; Nominatim is the fallback.
# 'nominatim'→ Nominatim (OpenStreetMap) is the primary; AWS is the fallback.
VITE_GEOCODING_PRIMARY_PROVIDER=nominatim

# Rate Limiting (requests per minute)
VITE_RATE_LIMIT_NOMINATIM=60
VITE_RATE_LIMIT_IBGE=120

# Feature Flags
VITE_ENABLE_SPEECH_SYNTHESIS=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=false

# Development Settings
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# Security
VITE_CSP_ENABLED=true
VITE_CORS_ENABLED=false
