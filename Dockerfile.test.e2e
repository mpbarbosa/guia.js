# Dockerfile.test.e2e — End-to-End (Puppeteer) Test Runner
#
# Runs `npm run test:e2e` inside an Alpine container with system Chromium.
# The app is compiled with `npm run build` so tests run against the real
# production bundle (no TS source-mode skips).
#
# Key design decisions:
#   1. node:20-alpine matches .nvmrc (20.19.0).
#   2. chromium is installed via apk — this avoids Puppeteer downloading its own
#      ~400 MB Chrome bundle during npm ci.
#   3. PUPPETEER_SKIP_DOWNLOAD=true prevents the bundled download.
#   4. PUPPETEER_EXECUTABLE_PATH points to the system Chromium binary.
#   5. Puppeteer tests already pass --no-sandbox and --disable-setuid-sandbox
#      (required when running as root inside Docker).
#   6. bessa_patterns.ts and paraty_geoservices are cloned at /workspace/ so
#      vite.config.js can resolve the 'bessa_patterns.ts' alias and the
#      resolveParatyGeoservicesCDN plugin can bundle paraty_geoservices inline
#      (eliminating runtime CDN fetches that would prevent networkidle0 in E2E tests).
#      The vite config falls back to src/index.ts when dist/index.mjs is absent,
#      so no separate build of the sibling repos is required.
#   7. TEST_SERVE_DIST=1 tells sanity.e2e.test.js to serve dist/ instead of src/.

FROM node:20-alpine

# Chromium, its shared-library dependencies, and git (for sibling repo clone)
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    git

# Tell Puppeteer to skip its bundled Chrome download and use system Chromium
ENV PUPPETEER_SKIP_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Clone sibling repos so vite.config.js aliases/plugins resolve during build:
#   - bessa_patterns.ts: required by resolve.alias in vite.config.js
#   - paraty_geoservices: required by resolveParatyGeoservicesCDN plugin so the
#     library is bundled inline (eliminates runtime CDN fetches in E2E tests)
WORKDIR /workspace
RUN git clone --depth 1 \
    https://github.com/mpbarbosa/bessa_patterns.ts.git

RUN git clone --depth 1 \
    --branch v1.2.5 \
    https://github.com/mpbarbosa/paraty_geoservices.git

# ─── Project setup ────────────────────────────────────────────────────────────

WORKDIR /workspace/guia_js

COPY package.json package-lock.json ./

# Override NODE_ENV before npm ci so devDependencies (Jest, Puppeteer, etc.) are installed.
ENV NODE_ENV=test
RUN npm ci --ignore-scripts

COPY . .

# Build the production bundle; tests are served from dist/
RUN npm run build

CMD ["npm", "run", "test:e2e"]
